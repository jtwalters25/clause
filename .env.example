# Supabase (pgvector) — shared project, Clause lives in its own `clause` schema
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Postgres schema Clause's tables live in (default: clause). Must be in Supabase
# Settings → API → Exposed schemas.
SUPABASE_SCHEMA=clause

# Embeddings — HuggingFace Inference API (general-purpose model; not academic SPECTER2)
HF_API_TOKEN=
EMBED_MODEL=sentence-transformers/all-mpnet-base-v2

# LLM — Anthropic (redline generation)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
